# Python bytecode
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
env/
ENV/

# Flask runtime files
instance/
uploads/
flask_session/

# Local databases
*.db
*.sqlite
*.sqlite3

# Environment variables and secrets
.env
.env.*
!.env.example

# Packet captures and raw network data
*.pcap
*.pcapng
*.cap
data/raw/
data/processed/

# Allow intentionally anonymised sample data
!data/samples/
!data/samples/**

# Test and coverage output
.pytest_cache/
.coverage
htmlcov/

# Jupyter
.ipynb_checkpoints/

# Editors and IDEs
.vscode/
.idea/
*.sublime-workspace

# Operating systems
.DS_Store
Thumbs.db

# Logs and temporary files
*.log
*.tmp
*.swp
